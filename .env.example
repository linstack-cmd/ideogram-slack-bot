# Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Ideogram API Key
IDEOGRAM_API_KEY=

# Ideogram API base URL (optional)
# Default: https://api.ideogram.ai
IDEOGRAM_BASE_URL=https://api.ideogram.ai

# Ideogram render speed: TURBO | QUALITY | DEFAULT (optional, default: TURBO)
IDEOGRAM_RENDER_SPEED=TURBO

# Ideogram aspect ratio (optional, default: ASPECT_1_1)
# Options: ASPECT_1_1, ASPECT_16_9, ASPECT_9_16, ASPECT_4_3, ASPECT_3_4, ASPECT_3_2, ASPECT_2_3, ASPECT_10_16, ASPECT_16_10
IDEOGRAM_ASPECT_RATIO=ASPECT_1_1

# Ideogram model (optional, default: V_2)
# Options: V_1, V_1_TURBO, V_2, V_2_TURBO, V_2A, V_2A_TURBO
IDEOGRAM_MODEL=V_2

# Log level: debug | info | warn | error (optional, default: info)
LOG_LEVEL=info
